    rgba(5, 8, 16, 0.9) !important;
}

.navigation-sidebar::before {
  content: "";
  position: sticky;
  top: -22px;
  display: block;
  height: 2px;
  margin: -22px -14px 18px;
  background: linear-gradient(90deg, var(--accent-cyan), var(--brand-purple), var(--brand-pink));
  box-shadow: 0 0 24px rgba(88, 166, 255, 0.26);
}

.nav-header > div:first-child {
  margin-bottom: 14px !important;
}

.identity-card-header,
.gauge-header,
.dashboard-card-label,
.dashboard-feed-title,
.pane-title-row h2 {
  text-shadow: 0 0 18px rgba(88, 166, 255, 0.10);
}

.nav-btn,
.nav-sub-btn {
  min-height: 42px;
}

.nav-btn::before,
.nav-sub-btn::before {
  content: "";
  position: absolute;
  inset: 6px auto 6px 0;
  width: 2px;
  border-radius: 999px;
  background: transparent;
  transition: background 0.2s ease, box-shadow 0.2s ease;
}

.nav-btn.active::before,
.nav-btn:hover::before,
.nav-sub-btn.active::before,
.nav-sub-btn:hover::before {
