/* STATUS: PLATIN */
/* GaiaCOM Nebula Visual Pass: design-only overrides, no behavior changes. */

:root {
  --bg-dark: #070a12;
  --bg-darker: #03050a;
  --bg-panel: rgba(13, 18, 32, 0.76);
  --bg-item: rgba(18, 25, 43, 0.78);
  --bg-elevated: rgba(20, 27, 48, 0.96);
  --bg-card: rgba(11, 16, 30, 0.94);
  --bg-active: rgba(88, 166, 255, 0.12);

  --border-color: rgba(117, 164, 255, 0.14);
  --border-glow: rgba(88, 166, 255, 0.34);
  --border-hover: rgba(167, 139, 250, 0.36);

  --accent-cyan: #58a6ff;
  --accent-violet: #8b5cf6;
  --accent-purple: #a78bfa;
  --accent-gradient: linear-gradient(135deg, #58a6ff 0%, #8b5cf6 48%, #ec4899 100%);
  --accent-glow: rgba(88, 166, 255, 0.32);

  --brand-purple: #8b5cf6;
  --brand-blue: #3b82f6;
  --brand-green: #10b981;
  --brand-orange: #f97316;
  --brand-pink: #ec4899;

  --text-primary: #eef3ff;
  --text-secondary: rgba(224, 232, 255, 0.78);
  --text-muted: #8fa2bf;

  --radius-sm: 8px;
  --radius-md: 8px;
  --radius-lg: 12px;

  --shadow-panel: 0 24px 70px rgba(0, 0, 0, 0.44);
  --shadow-card: 0 16px 42px rgba(0, 0, 0, 0.32);
  --hairline-top: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.16), transparent);
  --panel-surface: linear-gradient(180deg, rgba(255, 255, 255, 0.055), rgba(255, 255, 255, 0.018));
}

html,
body,
#root {
  background:
    linear-gradient(rgba(88, 166, 255, 0.035) 1px, transparent 1px),
    linear-gradient(90deg, rgba(88, 166, 255, 0.025) 1px, transparent 1px),
    radial-gradient(ellipse at 18% 0%, rgba(139, 92, 246, 0.22), transparent 44%),
    radial-gradient(ellipse at 82% 100%, rgba(16, 185, 129, 0.12), transparent 36%),
    var(--bg-dark);
  background-size: 54px 54px, 54px 54px, auto, auto, auto;
}

body::before {
  background:
    linear-gradient(115deg, transparent 0%, rgba(88, 166, 255, 0.08) 42%, transparent 62%),
    radial-gradient(ellipse at 12% 16%, rgba(139, 92, 246, 0.18), transparent 38%),
    radial-gradient(ellipse at 92% 18%, rgba(59, 130, 246, 0.14), transparent 42%);
  opacity: 0.82;
}

body::after {
  background:
    repeating-linear-gradient(0deg, rgba(255, 255, 255, 0.035) 0 1px, transparent 1px 7px),
    linear-gradient(180deg, rgba(3, 5, 10, 0), rgba(3, 5, 10, 0.58));
  filter: none;
  opacity: 0.32;
}

.app-container {
  grid-template-columns: 268px 392px minmax(0, 1fr);
  background:
    linear-gradient(90deg, rgba(255, 255, 255, 0.026), transparent 18%, transparent 82%, rgba(255, 255, 255, 0.018)),
    transparent;
}

.navigation-sidebar,
.mail-list-pane,
.mail-content-pane,
.group-sidebar {
  background:
    var(--panel-surface),
    rgba(7, 10, 18, 0.84);
  border-color: var(--border-color);
  box-shadow: inset -1px 0 0 rgba(255, 255, 255, 0.035);
}

.navigation-sidebar {
  padding: 22px 14px;
  gap: 12px;
}

.nav-header {
  margin-bottom: 10px;
}

.nav-header > div:first-child {
  border: 1px solid rgba(88, 166, 255, 0.14);
  border-radius: 8px;
  padding: 10px;
  background: rgba(255, 255, 255, 0.03);
  box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.06);
}

.logo-mark img {
  filter: drop-shadow(0 0 18px rgba(88, 166, 255, 0.22));
}

.identity-section {
  background:
    linear-gradient(135deg, rgba(88, 166, 255, 0.09), rgba(139, 92, 246, 0.075)) !important;
  border-color: rgba(88, 166, 255, 0.22) !important;
  box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.07), 0 12px 28px rgba(0, 0, 0, 0.24);
}

.nav-menu {
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.nav-btn,
.nav-sub-btn,
.theme-toggle-btn,
.btn-action,
.btn-secondary,
.btn-primary,
.mobile-menu-toggle,
.mobile-back-btn,
.chat-icon-btn {
  min-height: 38px;
  border-radius: 8px;
}

.nav-btn {
  padding: 10px 12px;
  background: rgba(255, 255, 255, 0.025);
  border: 1px solid transparent;
  color: var(--text-secondary);
  box-shadow: none;
}

.nav-btn svg {
  color: var(--text-muted);
  transition: transform 0.2s ease, color 0.2s ease;
}

.nav-btn:hover,
.nav-btn.active {
  transform: translateX(2px);
  color: #ffffff;
  background:
    linear-gradient(90deg, rgba(88, 166, 255, 0.18), rgba(139, 92, 246, 0.08)),
    rgba(255, 255, 255, 0.03);
  border-color: rgba(88, 166, 255, 0.28);
  box-shadow: inset 3px 0 0 var(--accent-cyan), 0 12px 26px rgba(0, 0, 0, 0.22);
}

.nav-btn:hover svg,
.nav-btn.active svg {
  color: var(--accent-cyan);
  transform: scale(1.06);
}

.nav-dropdown-sub {
  margin: 5px 0 7px 13px;
  padding: 4px 0 4px 11px;
  border-left: 1px solid rgba(88, 166, 255, 0.18);
}

.nav-sub-btn {
  padding: 8px 10px;
  color: var(--text-muted);
  background: transparent;
}

.nav-sub-btn:hover,
.nav-sub-btn.active {
  color: #ffffff;
  background: rgba(88, 166, 255, 0.1);
  border-color: rgba(88, 166, 255, 0.18);
}

.quantum-gauge,
.version-badge,
.glass-panel,
.mail-card,
.empty-action-card,
.profile-section-card,
.crypto-card,
.dashboard-card,
.security-panel,
.abuse-card,
.drop-card,
.vault-record-card,
.public-channel-card,
.drive-card,
.drive-item,
.notification-card,
.contact-profile-panel,
.contact-profile-hero {
  border-radius: 8px !important;
  background:
    var(--panel-surface),
    rgba(12, 18, 32, 0.74) !important;
  border-color: var(--border-color) !important;
  box-shadow: var(--shadow-card);
}

.quantum-gauge {
  margin-top: 10px;
  padding: 14px;
  border-color: rgba(16, 185, 129, 0.22) !important;
}

.gauge-bar {
  height: 6px;
  background: rgba(255, 255, 255, 0.08);
}

.gauge-fill {
  background: linear-gradient(90deg, var(--brand-green), var(--accent-cyan), var(--brand-purple));
  box-shadow: 0 0 18px rgba(16, 185, 129, 0.32);
}

.branding-footer {
  border-top-color: rgba(88, 166, 255, 0.16);
}

.mail-list-pane {
  border-right-color: rgba(88, 166, 255, 0.16);
}

.pane-header,
.reader-header,
.chat-reader-header,
.gsn-header,
.detail-mobile-actions {
  background:
    linear-gradient(180deg, rgba(10, 15, 28, 0.96), rgba(10, 15, 28, 0.76)) !important;
  border-bottom-color: rgba(88, 166, 255, 0.16) !important;
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
}

.pane-title-row h2,
.reader-subject,
.contact-profile-title,
.gsn-profile-name {
  color: #ffffff;
  font-family: var(--font-display);
  letter-spacing: 0;
}

.list-scroll {
  gap: 12px;
  padding: 18px;
}

.mail-card {
  position: relative;
  overflow: hidden;
  padding: 15px;
}

.mail-card::before,
.gsn-post-card::before,
.chat-bubble.incoming::before,
.public-channel-card::before,
.drive-card::before {
  content: "";
  position: absolute;
  inset: 0 0 auto;
  height: 1px;
  background: var(--hairline-top);
  pointer-events: none;
}

.mail-card:hover,
.mail-card.active {
  transform: translateY(-2px);
  border-color: var(--border-hover) !important;
  background:
    linear-gradient(135deg, rgba(88, 166, 255, 0.11), rgba(139, 92, 246, 0.065)),
    rgba(13, 18, 32, 0.86) !important;
  box-shadow: 0 18px 42px rgba(0, 0, 0, 0.34), 0 0 0 1px rgba(88, 166, 255, 0.08);
}

.mail-subject,
.gaiadrop-address-card span,
.auth-proof-grid strong,
.profile-section-title,
.contact-profile-grid label,
.contact-profile-eyebrow,
.pinned-title {
  color: var(--accent-cyan);
}

.mail-folders-row {
  background:
    linear-gradient(90deg, rgba(88, 166, 255, 0.08), transparent 28%),
    rgba(255, 255, 255, 0.018);
}

.mail-folder-pill,
.chat-security-chip,
.chat-date-divider span,
.message-reaction-strip span,
.gsn-badge,
.unread-badge,
.card-unread-badge {
  border-radius: 999px;
}

.mail-folder-pill.active,
.btn-primary,
.sidebar-publish-btn {
  background: var(--accent-gradient);
  color: #ffffff !important;
  border-color: transparent;
  box-shadow: 0 14px 34px rgba(139, 92, 246, 0.28);
}

.input-field,
.identity-select,
.custom-select-trigger,
.gsn-composer-textarea,
.gsn-comment-input,
textarea,
select {
  border-radius: 8px;
  background: rgba(5, 8, 16, 0.74);
  border-color: rgba(88, 166, 255, 0.16);
}

.input-field:focus,
.identity-select:focus,
.gsn-comment-input:focus,
textarea:focus,
select:focus {
  border-color: var(--accent-cyan);
  box-shadow: 0 0 0 3px rgba(88, 166, 255, 0.16), 0 0 24px rgba(88, 166, 255, 0.08);
}

.btn-primary:hover,
.btn-secondary:hover,
.btn-action:hover,
.theme-toggle-btn:hover,
.chat-icon-btn:hover,
.chat-icon-btn:focus-visible {
  transform: translateY(-1px);
  border-color: rgba(88, 166, 255, 0.32);
  box-shadow: 0 14px 34px rgba(0, 0, 0, 0.24), 0 0 20px rgba(88, 166, 255, 0.12);
}

.btn-secondary,
.btn-action,
.theme-toggle-btn,
.chat-icon-btn,
.mobile-menu-toggle,
.mobile-back-btn {
  background: rgba(255, 255, 255, 0.035);
  border-color: rgba(88, 166, 255, 0.16);
}

.chat-container {
  padding: 18px;
}

.chat-messages {
  background:
    linear-gradient(rgba(88, 166, 255, 0.024) 1px, transparent 1px),
    linear-gradient(90deg, rgba(88, 166, 255, 0.018) 1px, transparent 1px),
    rgba(5, 8, 16, 0.72);
  background-size: 36px 36px;
  border-color: rgba(88, 166, 255, 0.15);
  box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.04);
}

.chat-bubble {
  border-radius: 8px;
}

.chat-bubble.outgoing {
  background: linear-gradient(135deg, #3b82f6, #8b5cf6);
  box-shadow: 0 16px 36px rgba(59, 130, 246, 0.18);
}

.chat-bubble.incoming {
  position: relative;
  background: rgba(15, 22, 38, 0.88);
  border-color: rgba(88, 166, 255, 0.14);
}

.gsn-container {
  max-width: 760px;
  background: rgba(5, 8, 16, 0.22);
}

.gsn-header {
  padding: 14px 18px;
}

.gsn-tabs {
  border-radius: 8px;
  background: rgba(255, 255, 255, 0.035);
}

.gsn-tab {
  border-radius: 6px;
}

.gsn-tab.active {
  background: linear-gradient(135deg, rgba(88, 166, 255, 0.20), rgba(139, 92, 246, 0.18));
}

.gsn-composer {
  padding: 16px 18px;
  background:
    linear-gradient(135deg, rgba(88, 166, 255, 0.065), rgba(139, 92, 246, 0.04)),
    rgba(255, 255, 255, 0.018);
}

.gsn-composer-avatar,
.gsn-avatar,
.notification-avatar,
.user-avatar,
.user-avatar-sm {
  border-color: rgba(88, 166, 255, 0.22);
  box-shadow: 0 0 0 3px rgba(88, 166, 255, 0.055);
}

.gsn-post-card {
  position: relative;
  margin: 12px 14px;
  padding: 16px;
  border: 1px solid rgba(88, 166, 255, 0.13);
  border-radius: 8px;
  background:
    var(--panel-surface),
    rgba(11, 16, 30, 0.78);
  box-shadow: var(--shadow-card);
}

.gsn-post-card:hover {
  background:
    linear-gradient(135deg, rgba(88, 166, 255, 0.075), rgba(236, 72, 153, 0.035)),
    rgba(11, 16, 30, 0.88);
  border-color: rgba(88, 166, 255, 0.26);
}

.gsn-post-img,
.gsn-composer-preview-img,
.post-media-image {
  border-radius: 8px;
  border-color: rgba(88, 166, 255, 0.16);
}

.gsn-comments-section,
.gsn-comment-meta {
  border-radius: 8px;
  background: rgba(5, 8, 16, 0.48);
  border: 1px solid rgba(88, 166, 255, 0.11);
}

.gsn-action-btn:hover,
.gsn-action-btn.active {
  color: var(--accent-cyan);
  background: rgba(88, 166, 255, 0.1);
}

.reader-body,
.profile-container,
.composer-form,
.dashboard-grid,
.security-center,
.abuse-center,
.public-channels-container,
.drive-container,
.vault-container {
  background: transparent;
}

.popup-card,
.app-modal,
.gsn-drawer,
.chat-tools-dropdown,
.message-action-menu,
.emoji-picker,
.custom-select-options {
  border-radius: 8px;
  background:
    var(--panel-surface),
    rgba(8, 12, 22, 0.96);
  border-color: rgba(88, 166, 255, 0.18);
  box-shadow: 0 24px 70px rgba(0, 0, 0, 0.52);
}

.auth-card,
.wizard-card,
.unlock-card {
  border-radius: 10px !important;
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.07), rgba(255, 255, 255, 0.025)),
    rgba(8, 12, 22, 0.86) !important;
  border-color: rgba(88, 166, 255, 0.18) !important;
  box-shadow: 0 30px 90px rgba(0, 0, 0, 0.48), 0 0 0 1px rgba(255, 255, 255, 0.035);
}

body.light-mode {
  --bg-dark: #eef5fb;
  --bg-darker: #dfeaf4;
  --bg-panel: rgba(255, 255, 255, 0.86);
  --bg-item: rgba(255, 255, 255, 0.74);
  --bg-card: rgba(255, 255, 255, 0.9);
  --bg-active: rgba(88, 166, 255, 0.12);
  --border-color: rgba(28, 55, 86, 0.13);
  --border-glow: rgba(88, 166, 255, 0.18);
  --border-hover: rgba(99, 78, 210, 0.26);
  --text-primary: #102033;
  --text-secondary: #33475f;
  --text-muted: #63758c;
  --shadow-card: 0 16px 38px rgba(31, 57, 84, 0.13);
  --shadow-panel: 0 24px 70px rgba(31, 57, 84, 0.16);
}

body.light-mode .navigation-sidebar,
body.light-mode .mail-list-pane,
body.light-mode .mail-content-pane,
body.light-mode .group-sidebar,
body.light-mode .pane-header,
body.light-mode .reader-header,
body.light-mode .chat-reader-header,
body.light-mode .gsn-header,
body.light-mode .detail-mobile-actions {
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.94), rgba(246, 251, 255, 0.86)) !important;
}

body.light-mode .mail-card,
body.light-mode .gsn-post-card,
body.light-mode .chat-bubble.incoming,
body.light-mode .glass-panel,
body.light-mode .quantum-gauge {
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.94), rgba(246, 251, 255, 0.82)) !important;
}

@media (max-width: 1180px) {
  .app-container {
    grid-template-columns: 248px 350px minmax(0, 1fr);
  }
}

@media (max-width: 992px) {
  .app-container {
    grid-template-columns: 1fr !important;
    background:
      linear-gradient(rgba(88, 166, 255, 0.028) 1px, transparent 1px),
      linear-gradient(90deg, rgba(88, 166, 255, 0.02) 1px, transparent 1px),
      var(--bg-dark);
    background-size: 42px 42px;
  }

  .navigation-sidebar {
    width: min(300px, 86vw);
    background:
      linear-gradient(180deg, rgba(10, 15, 28, 0.98), rgba(7, 10, 18, 0.96)) !important;
    border-right-color: rgba(88, 166, 255, 0.28);
  }

  .app-container.mobile-menu-open::before {
    background: rgba(2, 4, 10, 0.72);
    backdrop-filter: blur(9px);
    -webkit-backdrop-filter: blur(9px);
  }

  .mail-list-pane .pane-header,
  .detail-mobile-actions {
    padding-left: max(14px, env(safe-area-inset-left));
    padding-right: max(14px, env(safe-area-inset-right));
  }

  .mobile-pane-actions .mobile-menu-toggle,
  .mobile-pane-actions .mobile-compose-btn,
  .detail-mobile-actions .mobile-menu-toggle,
  .detail-mobile-actions .mobile-back-btn,
  .mobile-floating-menu {
    border-radius: 8px;
    min-height: 36px;
  }

  .list-scroll {
    padding: 14px;
    gap: 10px;
  }

  .mail-card {
    padding: 14px;
  }

  .chat-container {
    padding: 12px;
  }

  .chat-bubble {
    max-width: min(86%, 560px);
    font-size: 0.9rem;
  }

  .gsn-container {
    max-width: 100%;
  }

  .gsn-header {
    padding: 12px 14px;
    gap: 10px;
  }

  .gsn-tabs {
    max-width: 100%;
    overflow-x: auto;
  }

  .gsn-tab {
    white-space: nowrap;
    padding: 6px 10px;
  }

  .gsn-composer {
    padding: 14px;
  }

  .gsn-post-card {
    margin: 10px 10px;
    padding: 14px;
  }

  .gsn-post-body,
  .gsn-reactions-row {
    padding-left: 0;
  }

  .gsn-post-header {
    gap: 10px;
  }

  .gsn-avatar,
  .gsn-composer-avatar {
    width: 38px;
    height: 38px;
  }
}

@media (max-width: 520px) {
  .pane-title-row {
    gap: 8px;
  }

  .pane-title-row h2 {
    font-size: 1.04rem !important;
  }

  .mail-card-header {
    gap: 8px;
  }

  .mail-sender,
  .mail-subject,
  .mail-preview,
  .gsn-post-gaiaid,
  .chat-peer-subline {
    overflow-wrap: anywhere;
  }

  .button-row,
  .modal-actions,
  .contact-profile-actions {
    gap: 8px;
  }

  .btn-primary,
  .btn-secondary,
  .btn-action {
    min-height: 40px;
  }
}

/* Nebula full-app stage */
.gaia-nebula-stage {
  position: fixed;
  inset: 0;
  z-index: -5;
  overflow: hidden;
  pointer-events: none;
  background:
    radial-gradient(ellipse at 18% 0%, rgba(88, 166, 255, 0.20), transparent 38%),
    radial-gradient(ellipse at 74% 18%, rgba(139, 92, 246, 0.18), transparent 34%),
    radial-gradient(ellipse at 52% 106%, rgba(16, 185, 129, 0.10), transparent 40%),
    #03050a;
}

.gaia-nebula-grid {
  position: absolute;
  inset: -2px;
  background:
    linear-gradient(rgba(88, 166, 255, 0.06) 1px, transparent 1px),
    linear-gradient(90deg, rgba(88, 166, 255, 0.045) 1px, transparent 1px);
  background-size: 58px 58px;
  mask-image: linear-gradient(180deg, rgba(0, 0, 0, 0.86), rgba(0, 0, 0, 0.18));
}

.gaia-nebula-scan {
  position: absolute;
  inset: 0;
  background: repeating-linear-gradient(
    180deg,
    rgba(255, 255, 255, 0.028) 0,
    rgba(255, 255, 255, 0.028) 1px,
    transparent 1px,
    transparent 8px
  );
  opacity: 0.28;
}

.gaia-nebula-beam {
  position: absolute;
  width: 58vw;
  height: 2px;
  transform-origin: left center;
  background: linear-gradient(90deg, transparent, rgba(88, 166, 255, 0.32), rgba(236, 72, 153, 0.18), transparent);
  filter: blur(0.5px);
}

.gaia-nebula-beam-a {
  top: 17%;
  left: -8%;
  transform: rotate(-10deg);
}

.gaia-nebula-beam-b {
  right: -10%;
  bottom: 21%;
  transform: rotate(14deg);
}

.app-container {
  position: relative;
  z-index: 1;
  isolation: isolate;
  border: 1px solid rgba(88, 166, 255, 0.10);
  box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.045);
}

.app-container::after {
  content: "";
  position: absolute;
  inset: 0;
  pointer-events: none;
  z-index: 30;
  background:
    linear-gradient(90deg, rgba(88, 166, 255, 0.09), transparent 10%, transparent 90%, rgba(139, 92, 246, 0.08)),
    linear-gradient(180deg, rgba(255, 255, 255, 0.04), transparent 18%, transparent 86%, rgba(0, 0, 0, 0.24));
  mix-blend-mode: screen;
  opacity: 0.46;
}

.app-container.mail-list-collapsed {
  grid-template-columns: 268px minmax(0, 1fr) !important;
}

.nebula-content-frame {
  position: relative;
  overflow: hidden;
}

.nebula-content-frame::before {
  content: "";
  position: absolute;
  inset: 0;
  z-index: 0;
  pointer-events: none;
  background:
    linear-gradient(120deg, rgba(88, 166, 255, 0.08), transparent 30%),
    radial-gradient(ellipse at 100% 0%, rgba(236, 72, 153, 0.08), transparent 36%),
    radial-gradient(ellipse at 0% 100%, rgba(16, 185, 129, 0.055), transparent 32%);
}

.nebula-content-frame > * {
  position: relative;
  z-index: 1;
}

.nebula-content-chrome {
  position: absolute;
  top: 12px;
  right: 14px;
  z-index: 3;
  display: flex;
  gap: 6px;
  pointer-events: none;
}

.nebula-content-chrome span {
  width: 7px;
  height: 7px;
  border-radius: 999px;
  background: rgba(88, 166, 255, 0.42);
  box-shadow: 0 0 12px rgba(88, 166, 255, 0.34);
}

.nebula-content-chrome span:nth-child(2) {
  background: rgba(139, 92, 246, 0.45);
}

.nebula-content-chrome span:nth-child(3) {
  background: rgba(16, 185, 129, 0.45);
}

/* Sidebar: command-system visual treatment */
