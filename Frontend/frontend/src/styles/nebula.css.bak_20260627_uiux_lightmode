}

.dashboard-card-icon {
  width: 42px;
  height: 42px;
  display: grid;
  place-items: center;
  border-radius: 8px;
  background: rgba(255, 255, 255, 0.08);
  border: 1px solid rgba(255, 255, 255, 0.10);
}

.dashboard-feed-pane,
.dashboard-active-channels-card {
  border-radius: 8px;
  background:
    var(--panel-surface),
