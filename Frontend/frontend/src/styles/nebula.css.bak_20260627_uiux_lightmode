}

.nebula-metric-card-purple {
  background:
    linear-gradient(145deg, rgba(139, 92, 246, 0.34), rgba(7, 10, 18, 0.74)),
    rgba(7, 10, 18, 0.82) !important;
}

.nebula-metric-card-green {
  background:
    linear-gradient(145deg, rgba(16, 185, 129, 0.25), rgba(7, 10, 18, 0.74)),
