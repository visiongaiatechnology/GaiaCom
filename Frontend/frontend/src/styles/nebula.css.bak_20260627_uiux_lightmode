    grid-template-columns: 1fr;
    overflow-y: auto;
  }

  .gsn-feed-column {
    min-height: 720px;
  }

  .gsn-right-rail {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    overflow: visible;
  }

  .gsn-mini-chat {
    grid-column: 1 / -1;
    min-height: 300px;
  }
}

@media (max-width: 720px) {
  .nebula-view-gsn .gsn-header {
    align-items: stretch;
    flex-direction: column;
  }

  .gsn-social-layout {
    padding: 10px;
  }

  .gsn-feed-column {
    min-height: 680px;
  }

  .nebula-view-gsn .gsn-feed-list {
    padding: 10px;
  }

  .nebula-view-gsn .gsn-post-card {
    padding: 14px;
  }

  .nebula-view-gsn .gsn-post-body,
  .nebula-view-gsn .gsn-reactions-row,
  .nebula-view-gsn .gsn-comments-section {
    padding-left: 0;
    margin-left: 0;
  }

  .gsn-right-rail {
    grid-template-columns: 1fr;
  }
}

/* Unified Nebula loader */
.gaia-transition-overlay,
.gaia-boot-overlay {
  background:
    radial-gradient(ellipse at 50% 35%, rgba(88, 166, 255, 0.18), transparent 30%),
    radial-gradient(ellipse at 40% 62%, rgba(139, 92, 246, 0.16), transparent 34%),
    linear-gradient(rgba(88, 166, 255, 0.045) 1px, transparent 1px),
    linear-gradient(90deg, rgba(88, 166, 255, 0.035) 1px, transparent 1px),
    #03050a !important;
  background-size: auto, auto, 52px 52px, 52px 52px, auto !important;
}

.gaia-transition-logo-container {
  position: relative;
  min-width: min(520px, calc(100vw - 40px));
  padding: 42px 34px;
  border: 1px solid rgba(88, 166, 255, 0.18);
  border-radius: 8px;
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.065), rgba(255, 255, 255, 0.018)),
    rgba(6, 10, 20, 0.78);
  box-shadow: 0 28px 90px rgba(0, 0, 0, 0.55), 0 0 70px rgba(88, 166, 255, 0.10);
}

.gaia-transition-logo-container::before {
  content: "";
  position: absolute;
  inset: 0 0 auto;
  height: 1px;
  background: var(--hairline-top);
}

.gaia-transition-text,
.gaia-boot-wordmark {
  font-family: var(--font-display) !important;
  letter-spacing: 0.14em !important;
  text-shadow: 0 0 28px rgba(88, 166, 255, 0.34) !important;
}

.gaia-transition-ring {
  border-radius: 8px !important;
  transform: rotate(45deg);
}

.gaia-transition-ring::before,
.gaia-transition-ring::after {
  border-radius: 8px !important;
}

/* Group sidebar refresh */
.group-chat-layout {
  background:
    linear-gradient(rgba(88, 166, 255, 0.026) 1px, transparent 1px),
    linear-gradient(90deg, rgba(88, 166, 255, 0.018) 1px, transparent 1px),
    rgba(4, 7, 14, 0.35);
  background-size: 42px 42px;
}

.group-sidebar {
  width: 300px;
  background:
    linear-gradient(180deg, rgba(12, 18, 34, 0.96), rgba(5, 8, 16, 0.90)),
    rgba(5, 8, 16, 0.92) !important;
  border-right-color: rgba(88, 166, 255, 0.16) !important;
  box-shadow: inset -1px 0 0 rgba(255, 255, 255, 0.04), 18px 0 42px rgba(0, 0, 0, 0.18);
}

.group-nav-row {
  padding: 16px;
  background:
    linear-gradient(135deg, rgba(88, 166, 255, 0.09), rgba(139, 92, 246, 0.05)),
    rgba(255, 255, 255, 0.02);
}

.group-room-title {
  font-family: var(--font-display);
  font-size: 1rem;
}

.channel-list,
.group-members-list,
.group-policy-box,
.group-leave-box {
  padding-left: 14px;
  padding-right: 14px;
}

.channel-list {
  gap: 7px;
  background: rgba(255, 255, 255, 0.018);
}

.channel-item,
.group-member-item {
  border: 1px solid rgba(88, 166, 255, 0.10);
  border-radius: 8px;
  background: rgba(255, 255, 255, 0.028);
  padding: 10px;
}

.channel-item:hover,
.channel-item.active,
.group-member-item:hover {
  background:
    linear-gradient(90deg, rgba(88, 166, 255, 0.12), rgba(139, 92, 246, 0.055));
  border-color: rgba(88, 166, 255, 0.26);
  color: #ffffff;
}

.group-sidebar-title,
.channel-header,
.group-policy-title {
  margin-left: 14px;
  margin-right: 14px;
  color: var(--accent-cyan);
}

/* Chat dock refresh */
.chat-composer-stack.nebula-composer-dock {
  display: grid;
  gap: 8px;
  border-color: rgba(88, 166, 255, 0.18);
  background:
    linear-gradient(135deg, rgba(88, 166, 255, 0.07), rgba(139, 92, 246, 0.04)),
    rgba(5, 8, 16, 0.88);
}

.chat-composer-stack.nebula-composer-dock::before {
  content: "";
  display: block;
  height: 1px;
  background: linear-gradient(90deg, transparent, rgba(88, 166, 255, 0.42), transparent);
}

.chat-input-row.nebula-chat-input-row {
  grid-template-columns: auto minmax(0, 1fr) auto;
  border: 1px solid rgba(88, 166, 255, 0.12);
  border-radius: 8px;
  padding: 8px;
  background: rgba(2, 5, 12, 0.56);
}

.chat-input-row.nebula-chat-input-row .emoji-toggle,
.chat-input-row.nebula-chat-input-row .btn-secondary {
  min-width: 40px;
  height: 40px;
  margin-top: 0;
}

/* GSN bottom dock model */
.gsn-social-layout {
  grid-template-columns: minmax(620px, 900px) minmax(320px, 380px);
}

.gsn-right-rail {
  padding-bottom: 118px;
}

.gsn-mini-chat {
  position: fixed;
  right: 24px;
  bottom: 18px;
  z-index: 50;
  width: min(380px, calc(100vw - 32px));
  min-height: 0;
  max-height: 72px;
  overflow: visible;
  border-color: rgba(88, 166, 255, 0.22);
  box-shadow: 0 22px 60px rgba(0, 0, 0, 0.48), 0 0 44px rgba(88, 166, 255, 0.10);
}

.gsn-mini-chat .gsn-rail-header {
  min-height: 54px;
  border-bottom: 0;
  cursor: default;
}

.gsn-mini-chat .gsn-mini-contact-strip,
.gsn-mini-chat .gsn-mini-chat-window,
.gsn-mini-chat .gsn-mini-chat-form {
  display: none;
}

.gsn-mini-chat:hover,
.gsn-mini-chat:focus-within {
  max-height: min(620px, calc(100vh - 110px));
}

.gsn-mini-chat:hover .gsn-mini-contact-strip,
.gsn-mini-chat:hover .gsn-mini-chat-window,
.gsn-mini-chat:hover .gsn-mini-chat-form,
.gsn-mini-chat:focus-within .gsn-mini-contact-strip,
.gsn-mini-chat:focus-within .gsn-mini-chat-window,
.gsn-mini-chat:focus-within .gsn-mini-chat-form {
  display: flex;
}

.gsn-mini-chat:hover .gsn-mini-chat-form,
.gsn-mini-chat:focus-within .gsn-mini-chat-form {
  display: grid;
}

.gsn-mini-chat-window {
  min-height: 260px;
  max-height: min(390px, calc(100vh - 270px));
}

.gsn-rail-card:not(.gsn-mini-chat) {
  min-height: 0;
}

.gsn-rail-list {
  max-height: 260px;
  overflow-y: auto;
}

.snapshot-warning {
  margin-top: 8px;
  border: 1px solid rgba(251, 191, 36, 0.22);
  border-radius: 8px;
  background: rgba(251, 191, 36, 0.08);
  color: var(--warning);
  font-size: 0.76rem;
  font-weight: 800;
  padding: 8px 10px;
}

/* Chat tools overlay */
.chat-reader-header {
  overflow: visible !important;
  isolation: isolate;
  z-index: 90;
}

.glass-panel.chat-tools-dropdown {
  z-index: 2400 !important;
}

.chat-messages {
  position: relative;
  z-index: 1;
}

@media (max-width: 1100px) {
  .group-sidebar {
    width: 100%;
  }

  .gsn-mini-chat {
    right: 12px;
    bottom: calc(12px + env(safe-area-inset-bottom));
  }
}

@media (max-width: 720px) {
  .chat-input-row.nebula-chat-input-row {
    grid-template-columns: 1fr;
  }

  .gsn-right-rail {
    padding-bottom: 90px;
  }

  .gsn-mini-chat {
    left: 10px;
    right: 10px;
    width: auto;
  }
}
