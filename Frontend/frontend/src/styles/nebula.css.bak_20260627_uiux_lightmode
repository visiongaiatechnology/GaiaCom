}

.mail-time button:hover,
.chat-delete-btn:hover,
.gsn-drawer-close:hover {
  transform: translateY(-1px);
}

/* Dashboard: modern command board */
.dashboard-container {
  position: relative;
  padding: 30px;
  background:
    linear-gradient(rgba(88, 166, 255, 0.035) 1px, transparent 1px),
