}

.dashboard-feed-item {
  border-radius: 8px;
  background: rgba(255, 255, 255, 0.032);
}

.dashboard-feed-item-avatar,
.dashboard-empty-state-icon,
.chat-peer-icon {
  border-radius: 8px;
